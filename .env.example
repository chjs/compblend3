# compblend3 environment variables template
# 이 파일을 `.env`로 복사한 뒤 실제 값을 채운다.
# `.env`는 `.gitignore`에 포함되어 있다.

# Hugging Face token (Mistral-7B-Instruct-v0.2는 gated)
# MacBook에서는 보통 비워둠 (실험 안 함). vast.ai와 local_a100에서만 필요.
HF_TOKEN=

# 모델/데이터 캐시 경로 (선택, 비우면 default ~/.cache/huggingface)
HF_HOME=

# vast.ai API key (Claude Code의 step별 인스턴스 자동 할당/destroy에 필수 — DECISIONS.md §8.4)
VAST_API_KEY=

# Loong 데이터셋 경로 (수동 다운로드한 경우, vast.ai/local_a100에서만 필요)
LOONG_DATA_DIR=

# 환경 태그 (3개 중 하나)
# - macbook    : Claude Code 실행 환경 (smoke test만)
# - vastai     : primary 실험 환경
# - local_a100 : occasional 검증 환경
# 자동 감지되지만 명시하는 것 권장. install_*.sh 가 자동으로 설정.
# COMPBLEND_ENV_TAG=vastai
